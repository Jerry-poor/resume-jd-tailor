# Copy to `.env` (not committed) and fill in keys if you want LLM rewriting.

# DeepSeek (text JD)
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Vertex AI (image JD -> Gemini)
# Your GCP auth must be configured separately (ADC).
VERTEX_PROJECT_ID=
VERTEX_LOCATION=global
GEMINI_MODEL=gemini-3-flash-preview
